{
  "name": "cinegen-desktop",
  "productName": "CineGen",
  "version": "1.0.0",
  "description": "AI Film Production Studio — Desktop Application",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "build:native": "node scripts/build-native-avf.mjs",
    "dev": "npm run build:native && vite",
    "build": "npm run build:native && vite build",
    "preview": "npm run build && electron .",
    "package": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.cinegen.desktop",
    "productName": "CineGen",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*",
      "electron/**/*",
      "native/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "icon": "build/CineGen.icns",
      "category": "public.app-category.video"
    }
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.4",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  }
}
