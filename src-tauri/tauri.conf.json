{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CineGen",
  "version": "0.1.0",
  "identifier": "com.cinegen.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev --host 127.0.0.1 --port 5173 --strictPort",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CineGen",
        "width": 1600,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
